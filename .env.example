# Copy to .env and set your keys

# Required in production. For local dev, a default is used if unset.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-64-char-hex-secret

# ----- AI provider: set ONE key (or more; first one wins unless AI_PROVIDER is set) -----

# Option 1 — OpenAI (paid): https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Option 2 — Groq (FREE, 14 400 req/day, fast): https://console.groq.com → "Create API Key"
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile
# If you use Groq, unset OPENAI_BASE_URL (e.g. local proxy) or the app will force Groq's URL.

# Option 3 — Google AI Studio / Gemini (free tier): https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=your-google-ai-key
# GOOGLE_AI_MODEL=gemini-2.0-flash

# Option 4 — Hugging Face Inference API (free tier): https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_your-key-here
# HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# Force a specific provider (optional — unset = first configured key is used)
# AI_PROVIDER=openai
# AI_PROVIDER=groq
# AI_PROVIDER=google
# AI_PROVIDER=huggingface

# Optional: SMTP for password reset emails
# Any SMTP provider works. For Gmail, create an App Password:
#   https://myaccount.google.com/apppasswords (requires 2-Step Verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=you@gmail.com   # defaults to SMTP_USER if unset

# Optional: server port (default: 3000)
# PORT=3000

# Optional: Google OAuth for "Connect Google account" on the home page (per-account statistics)
# Create a project in Google Cloud Console, enable Google+ API / People API, create OAuth 2.0 credentials.
# Add authorized redirect URI: http://localhost:3000/login/google/authorized (or your base URL + /login/google/authorized)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Optional: proctor for mock exam (see proctor/README.md). Default uses ../proctor (wrk/proctor).
# PROCTOR_DIR=../proctor
# PROCTOR_ENABLED=1
# PROCTOR_NAME=My proctor
# When using wrk/proctor: backend and frontend URLs (FCE calls backend and redirects to frontend)
# PROCTOR_BACKEND_URL=http://localhost:8000
# PROCTOR_FRONTEND_URL=http://localhost:5173
# PROCTOR_EXAM_CODE=DEMO
